# Скопируйте в .env: cp .env.example .env

# --- Обязательные ---
ADMIN_PASSWORD=your-secret-site-password
JWT_SECRET_KEY=change-me-to-a-long-random-secret-min-32-chars
DB_PASSWORD=postgres

# --- PostgreSQL ---
# Локальный backend (без Docker): DB_HOST=localhost, DB_PORT=5433 если Postgres в Docker
# Внутри docker compose DB_HOST задаётся автоматически (postgres)
DB_HOST=localhost
DB_PORT=5432
DB_HOST_PORT=5433
DB_NAME=tg_bots
DB_USER=postgres

# --- Redis (очередь задач worker) ---
REDIS_URL=redis://localhost:6379/0
REDIS_JOB_QUEUE=tg_bots:creation_jobs
REDIS_PREP_QUEUE=tg_bots:account_prep_jobs

# --- Приложение ---
APP_NAME=Telegram Bots Generator
ENVIRONMENT=development
PORT=5000
LOG_LEVEL=INFO
STORAGE_ROOT=./storage

# --- Шифрование токенов ботов (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
BOT_TOKEN_ENCRYPTION_KEY=

# --- CORS и URL ---
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# --- Лимиты ---
MAX_BOTS_PER_ACCOUNT=20
BOT_RUNNER_RELOAD_INTERVAL_SEC=60

# --- AI (бесплатно: Groq + Pollinations) ---
AI_TEXT_PROVIDER=groq
AI_IMAGE_PROVIDER=pollinations
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Локальная альтернатива текста:
# AI_TEXT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Telegram (для Telethon / создания ботов) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Frontend (Vite, docker build) ---
VITE_API_BASE_URL=/api/v1
