# HTTPS + reverse proxy → frontend (nginx внутри Docker)
# SITE_DOMAIN и ACME_EMAIL задаются в docker-compose / .env
# Не используйте {$VAR:default@email} — символ @ ломает разбор Caddyfile

{
	email {$ACME_EMAIL}
	# Только Let's Encrypt (ZeroSSL часто отклоняет .ru-домены при fallback)
	acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# Основной сайт
{$SITE_DOMAIN}, www.{$SITE_DOMAIN} {
	reverse_proxy frontend:80
}

# neuro-com-admin — только если запущен соседний compose-проект в сети telegrambotsautogenerating_tgbots.
# Если neuro.tg-bots-generate.ru не нужен — закомментируйте блок ниже (иначе Caddy отдаёт 502).
# neuro.{$SITE_DOMAIN} {
# 	reverse_proxy neuro-com-admin:8443
# }
