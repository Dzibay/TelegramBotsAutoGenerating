# HTTPS + reverse proxy → frontend (nginx внутри Docker)
# SITE_DOMAIN, ACME_EMAIL, NEURO_ENABLED — docker-compose / .env
# Не используйте {$VAR:default@email} — символ @ ломает разбор Caddyfile

{
	email {$ACME_EMAIL}
	# Только Let's Encrypt (ZeroSSL часто отклоняет .ru-домены при fallback)
	acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# Основной сайт
{$SITE_DOMAIN}, www.{$SITE_DOMAIN} {
	reverse_proxy frontend:80
}

# neuro-com-admin — опционально (отдельный compose в сети telegrambotsautogenerating_tgbots).
# NEURO_ENABLED=false (по умолчанию): 503 без reverse_proxy — нет 502 и spam в логах от ботов.
# NEURO_ENABLED=true: прокси на neuro-com-admin:8443 (контейнер должен быть в той же Docker-сети).
neuro.{$SITE_DOMAIN} {
	log {
		level ERROR
	}

	@neuro expression {env.NEURO_ENABLED} == 'true'
	handle @neuro {
		reverse_proxy neuro-com-admin:8443 {
			transport http {
				dial_timeout 3s
			}
			fail_duration 5m
		}
	}

	handle {
		respond "" 503
	}
}
