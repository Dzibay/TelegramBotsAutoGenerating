# --- Обязательные (замените перед продакшеном) ---
ADMIN_PASSWORD=1234
JWT_SECRET_KEY=change-me-generate-32plus-random-chars-openssl-rand-hex-32
DB_PASSWORD=change-me-strong-postgres-password

# Fernet для шифрования токенов ботов в БД (обязательно в production):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BOT_TOKEN_ENCRYPTION_KEY=azqOj2G-qCE5Hhgrf0ewVTreNFWDXpsP6onstptIpvQ=

# --- PostgreSQL ---
# В docker compose DB_HOST/DB_PORT переопределяются на postgres:5432
# DB_HOST_PORT — только проброс на хост (для pgAdmin/бэкапов), не открывайте в интернет
DB_HOST=postgres
DB_PORT=5432
DB_HOST_PORT=5433
DB_NAME=tg_bots
DB_USER=postgres
DB_POOL_MIN=1
DB_POOL_MAX=10

# --- Redis ---
# В docker compose: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=6379
REDIS_JOB_QUEUE=tg_bots:creation_jobs
REDIS_PREP_QUEUE=tg_bots:account_prep_jobs

# --- Приложение ---
APP_NAME=Telegram Bots Generator
ENVIRONMENT=production
PORT=5000
LOG_LEVEL=INFO
# В контейнерах переопределяется на /app/storage (volume tdata_storage)
STORAGE_ROOT=/app/storage

# --- Домен (Caddy в docker compose: порты 80/443, авто-SSL) ---
SITE_DOMAIN=tg-bots-generate.ru
ACME_EMAIL=you@example.com

# --- URL и CORS (домен tg-bots-generate.ru) ---
# Укажите оба варианта, если используете www и без www
CORS_ORIGINS=https://tg-bots-generate.ru,https://www.tg-bots-generate.ru
FRONTEND_URL=https://tg-bots-generate.ru
BACKEND_URL=https://tg-bots-generate.ru
# Базовый URL для трекинг-ссылок ботов: https://tg-bots-generate.ru/go/{slug}
PUBLIC_SITE_URL=https://tg-bots-generate.ru

# JWT (дней)
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# --- Лимиты ---
MAX_BOTS_PER_ACCOUNT=20
BOT_RUNNER_RELOAD_INTERVAL_SEC=60

# --- AI ---
# groq | ollama | none (только шаблоны без нейросети)
AI_TEXT_PROVIDER=groq
AI_FALLBACK_ON_ERROR=true
AI_IMAGE_PROVIDER=pollinations
# Ключ: https://console.groq.com → API Keys → Create
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Локальная альтернатива (только если Ollama на том же сервере):
# AI_TEXT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Telegram API (https://my.telegram.org → API development tools) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Frontend (сборка Docker / Vite) ---
# Оставьте /api/v1 — nginx проксирует /api на backend
VITE_API_BASE_URL=/api/v1

